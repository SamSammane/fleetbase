        "lint:js": "eslint . --cache",
        "lint:hbs": "ember-template-lint .",
        "start": "ember serve",
        "test:ember": "ember test"
    },
    "dependencies": {
        "@fleetbase/ember-core": "^0.3.24",
        "@fleetbase/ember-ui": "^0.3.39",
        "@fleetbase/fleetops-data": "^0.1.40",
        "ember-auto-import": "^2.7.0",
        "ember-cli-babel": "^8.2.0",
