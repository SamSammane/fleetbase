    "fleetbase": {
        "route": "commandiq"
    },
    "keywords": [
        "fleetbase-extension",
        "commandiq",
        "fleetbase",
        "ember-addon",
        "ember-engine"
    ],
    "license": "proprietary",
    "author": "Integrated Fleet Solutions (IFS) <sam@qgi.dev>",
    "directories": {
        "app": "app",
        "addon": "addon",
        "tests": "tests"
    },
    "scripts": {
